{
  "name": "just-code",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "justcode": "./dist/justcode.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx --env-file=.env apps/cli/src/index.tsx",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@shikijs/cli": "^4.2.0",
    "chalk": "5",
    "cli-table3": "^0.6.5",
    "commander": "^13.1.0",
    "ink": "^5.2.1",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "marked": "^15.0.12",
    "marked-shiki": "^1.2.1",
    "marked-terminal": "^7.3.0",
    "react": "^18.3.1",
    "shiki": "^4.2.0"
  },
  "devDependencies": {
    "@types/marked-terminal": "^6.1.1",
    "@types/node": "^24.0.3",
    "@types/react": "^18.3.3",
    "prettier": "^3.5.3",
    "tsup": "^8.2.4",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^2.1.8"
  }
}
