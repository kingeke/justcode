{
  "name": "just-code",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "justcode": "./dist/justcode.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "bun apps/cli/src/index.tsx",
    "dev:watch": "bun --watch apps/cli/src/index.tsx",
    "try:tools": "tsx scripts/try-tools.ts",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@opentui/core": "^0.4.2",
    "@opentui/react": "^0.4.2",
    "@shikijs/cli": "^4.2.0",
    "chalk": "5",
    "commander": "^13.1.0",
    "diff": "^9.0.0",
    "marked": "^15.0.12",
    "marked-shiki": "^1.2.1",
    "marked-terminal": "^7.3.0",
    "react": "^19.2.0",
    "shiki": "^4.2.0"
  },
  "devDependencies": {
    "@types/marked-terminal": "^6.1.1",
    "@types/node": "^24.0.3",
    "@types/react": "^19.2.0",
    "prettier": "^3.5.3",
    "tsup": "^8.2.4",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^2.1.8"
  }
}
