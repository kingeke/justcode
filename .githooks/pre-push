#!/bin/sh
# Pre-push hook: run Prettier formatting check, typecheck, and tests before
# allowing a push. Bypass with `git push --no-verify` when needed.

set -e

echo "▶ Running Prettier check..."
bun run prettier --check .

echo "▶ Running typecheck..."
bun run typecheck

echo "▶ Running tests..."
bun run test

echo "✓ Pre-push checks passed."
